{
  "name": "margv",
  "version": "1.1.6",
  "description": "simple node.js argv parser",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.mjs"
    }
  },
  "scripts": {
    "serve": "tsc ./src/index.ts --watch --outDir ./dev",
    "build": "node build.mjs",
    "test": "npm run build && mocha ./test/*.spec.ts"
  },
  "keywords": [
    "argv",
    "cli",
    "process.argv",
    "argv parser"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/webigorkiev/margv.git"
  },
  "author": "webigorkiev",
  "license": "MIT",
  "devDependencies": {
    "@types/mocha": "^8.2.2",
    "@types/node": "^15.6.1",
    "chai": "^4.3.4",
    "mocha": "^8.4.0",
    "terser": "^5.7.0",
    "ts-mocha": "^8.0.0",
    "typescript": "^4.3.2",
    "margv": "^1.0.3"
  }
}
